{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlaySP2Manager",
  "version": "0.4.0",
  "identifier": "com.slay.sp2manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SlaySP2Manager",
        "width": 1440,
        "height": 960,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": ["icons/icon.ico"],
    "createUpdaterArtifacts": "v1Compatible"
  }
}
