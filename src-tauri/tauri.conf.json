{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "SlaySP2Manager",
  "version": "0.7.0",
  "identifier": "com.slay.sp2manager",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm.cmd run dev",
    "beforeBuildCommand": "npm.cmd run build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "SlaySP2Manager",
        "width": 1440,
        "height": 960,
        "minWidth": 800,
        "minHeight": 520,
        "resizable": true,
        "decorations": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/wakaka6/SlaySP2Manger/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDk3OEIxNjUwNjhCMzM4QUQKUldTdE9MTm9VQmFMbHpBdkxpOGdZRHJ1R2dXckFRSEZuTGJJNk5zajN2RjA0QTEzQ3ppSXdDOWwK"
    }
  },
  "bundle": {
    "active": true,
    "targets": "msi",
    "icon": ["icons/icon.ico"],
    "createUpdaterArtifacts": "v1Compatible"
  }
}
